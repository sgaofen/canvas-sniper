{
    "manifest_version": 3,
    "name": "Canvas Sniper",
    "version": "2.2",
    "description": "Canvas Quiz 自动答题助手",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "*://*.instructure.com/*",
        "*://*.edu/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.instructure.com/*",
                "*://*.edu/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}